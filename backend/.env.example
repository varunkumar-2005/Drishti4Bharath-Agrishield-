# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# S3
S3_BUCKET=agroshield-trade-data
S3_KEY=raw-data/trade_dataset.csv
MODEL_KEY=model-artifacts/risk_model.pkl
ENCODERS_KEY=model-artifacts/encoders.pkl
FEATURES_KEY=model-artifacts/feature_columns.pkl

# DynamoDB
USE_DYNAMO=true
DYNAMO_EVENTS_TABLE=agroshield-events
DYNAMO_ADVISORIES_TABLE=agroshield-advisories

# Amazon Bedrock
BEDROCK_MODEL=amazon.nova-lite-v1:0
BEDROCK_FALLBACK_MODEL=amazon.nova-lite-v1:0
FARMER_CHAT_MODEL=amazon.nova-lite-v1:0
FARMER_CHAT_MAX_TOKENS=600

# Pipeline
PIPELINE_INTERVAL_SECONDS=300

# Event source
# gdelt = real-time API mode
# file = read from MOCK_GDELT_FILE
EVENT_SOURCE=gdelt
MOCK_GDELT_FILE=data/agroshield_headlines.csv
# For quick Bedrock validation on only first headline from file source
FILE_EVENT_LIMIT=1

# Local fallback CSV (used if S3 unavailable)
LOCAL_CSV=data/trade_dataset.csv
